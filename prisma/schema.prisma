generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Client {
  id        Int      @id @default(autoincrement())
  name      String
  address   String?
  phone     String?
  email     String?
  notes     String?
  units     ClientUnit[]
  quotes    Quote[]
emailNotifications EmailNotifications[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ClientUnit {
  id           Int      @id @default(autoincrement())
  clientId     Int
  brand        String
  model        String
  powerKw      Float?
  serialNumber String?
  installation DateTime?
  periodMonths Int      @default(12)
  location     String?
  notes        String?
  maintenance  MaintenanceLog[]

 emailNotifications EmailNotifications[]

  client   Client @relation(fields: [clientId], references: [id])
}

model MaintenanceLog {
  id            Int      @id @default(autoincrement())
  unitId        Int
  performedDate DateTime
  description   String?
  materials     String?
  costInternal  Int?
  technicianId  Int?
  nextDue       DateTime?
  photos        String?

  unit ClientUnit @relation(fields: [unitId], references: [id])
}

model Quote {
  id         Int         @id @default(autoincrement())
  clientId   Int
  quoteNo    String      @unique
  dateIssued DateTime    @default(now())
  status     String      @default("draft")
  netTotal   Int?
  vatAmount  Int?
  grossTotal Int?
  profit     Int?
  terms      String?
  pdfPath    String?

  client Client      @relation(fields: [clientId], references: [id])
  items  QuoteItem[]
}

model QuoteItem {
  id            Int      @id @default(autoincrement())
  quoteId       Int
  name          String
  basePriceNet  Int
  profitValue   Int
  profitType    String
  finalPriceNet Int
  qty           Int      @default(1)

  quote Quote @relation(fields: [quoteId], references: [id])
}

model EmailNotifications {
  id               Int         @id @default(autoincrement())
  clientId         Int
  clientUnitId     Int
  notificationType String
  sentToEmail      String
  sentAt           DateTime    @default(now())
  status           String

  client           Client      @relation(fields: [clientId], references: [id])
  unit             ClientUnit  @relation(fields: [clientUnitId], references: [id])
}

enum QuoteStatus {
  draft
  sent
  accepted
  rejected
}

model Quote {
  id         Int          @id @default(autoincrement())
  clientId   Int
  client     Client       @relation(fields: [clientId], references: [id])
  title      String?
  status     QuoteStatus  @default(draft)
  terms      String?

  // Összegek (nettó/áfa/bruttó) – pénzügyi pontosság miatt Decimal
  netTotal   Decimal      @default(0)
  vatAmount  Decimal      @default(0)
  grossTotal Decimal      @default(0)

  items      QuoteItem[]

  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

model QuoteItem {
  id            Int      @id @default(autoincrement())
  quoteId       Int
  quote         Quote    @relation(fields: [quoteId], references: [id])

  description   String
  quantity      Decimal  @default(1)   // mennyiség
  unit          String?                // mértékegység (pl. db, óra)
  unitPriceNet  Decimal  @default(0)   // nettó egységár
  vatRate       Decimal  @default(27)  // ÁFA %

  // Sorösszegek – a backend számolja ki mentéskor
  lineNet       Decimal  @default(0)
  lineVat       Decimal  @default(0)
  lineGross     Decimal  @default(0)

  // (opcionális) költség és profit
  costNet       Decimal?
  profitAbs     Decimal?
  profitPct     Decimal?

  createdAt     DateTime @default(now())
}
